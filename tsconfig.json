{
    "compilerOptions": {
        "target": "ESNext",
        "module": "nodenext", //old: "ESNext",
        "moduleResolution": "nodenext", //old: "Node",
        "rootDir": "./",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node", "jest"]
    },
    "include": ["src/**/*", "_tests/**/*"],
    "exclude": ["node_modules"]
}
