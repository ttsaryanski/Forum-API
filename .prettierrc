{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "printWidth": 80,
    "overrides": [
        {
            "files": "*.yml",
            "options": {
                "tabWidth": 2,
                "useTabs": false,
                "printWidth": 120
            }
        },
        {
            "files": "*.yaml",
            "options": {
                "tabWidth": 2,
                "useTabs": false,
                "printWidth": 120
            }
        }
    ]
}
